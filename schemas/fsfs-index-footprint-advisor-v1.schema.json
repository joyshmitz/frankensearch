{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frankensearch.dev/schemas/fsfs-index-footprint-advisor-v1.schema.json",
  "title": "fsfs Index Footprint Advisor v1",
  "oneOf": [
    {
      "$ref": "#/$defs/contractDefinition"
    },
    {
      "$ref": "#/$defs/advisorReport"
    }
  ],
  "$defs": {
    "domain": {
      "type": "string",
      "enum": [
        "vector_index",
        "lexical_index",
        "metadata",
        "model_cache",
        "artifact"
      ]
    },
    "scenario": {
      "type": "string",
      "enum": [
        "small",
        "fragmented",
        "oversized"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "compaction",
        "rebuild",
        "retention",
        "feature_adjustment"
      ]
    },
    "risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "reasonCode": {
      "type": "string",
      "pattern": "^index_footprint\\.[a-z0-9_.]+$"
    },
    "replayCommand": {
      "type": "string",
      "pattern": "^FSFS_INDEX_FOOTPRINT_FIXTURE=(small|fragmented|oversized) FSFS_INDEX_FOOTPRINT_DOMAIN=(vector_index|lexical_index|metadata|model_cache|artifact) cargo test -p frankensearch-fsfs index_footprint_advisor_policy_suite -- --nocapture$"
    },
    "contractDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "v",
        "dry_run_only",
        "automatic_deletion_allowed",
        "policy_version",
        "required_domains",
        "required_actions",
        "policy",
        "replay_command_template"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "fsfs_index_footprint_advisor_contract"
        },
        "v": {
          "type": "integer",
          "const": 1
        },
        "dry_run_only": {
          "type": "boolean",
          "const": true
        },
        "automatic_deletion_allowed": {
          "type": "boolean",
          "const": false
        },
        "policy_version": {
          "type": "string",
          "const": "fsfs-index-footprint-advisor-policy-v1"
        },
        "required_domains": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/domain"
          }
        },
        "required_actions": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/action"
          }
        },
        "policy": {
          "$ref": "#/$defs/policy"
        },
        "replay_command_template": {
          "type": "string",
          "pattern": "^FSFS_INDEX_FOOTPRINT_FIXTURE=\\{scenario\\} FSFS_INDEX_FOOTPRINT_DOMAIN=\\{domain\\} cargo test -p frankensearch-fsfs index_footprint_advisor_policy_suite -- --nocapture$"
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "small_index_max_bytes",
        "fragmentation_threshold_per_mille",
        "oversize_threshold_per_mille",
        "dominant_domain_threshold_per_mille",
        "minimum_projected_savings_bytes"
      ],
      "properties": {
        "small_index_max_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "fragmentation_threshold_per_mille": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "oversize_threshold_per_mille": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2000
        },
        "dominant_domain_threshold_per_mille": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "minimum_projected_savings_bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "advisorReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "v",
        "generated_at",
        "surface",
        "policy_version",
        "scenario",
        "dry_run",
        "automatic_deletion_allowed",
        "budget_bytes",
        "total_bytes",
        "measurements",
        "recommendations",
        "summary"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "fsfs_index_footprint_advisor_report"
        },
        "v": {
          "type": "integer",
          "const": 1
        },
        "generated_at": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "type": "string",
          "minLength": 1
        },
        "policy_version": {
          "type": "string",
          "const": "fsfs-index-footprint-advisor-policy-v1"
        },
        "scenario": {
          "$ref": "#/$defs/scenario"
        },
        "dry_run": {
          "type": "boolean",
          "const": true
        },
        "automatic_deletion_allowed": {
          "type": "boolean",
          "const": false
        },
        "budget_bytes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "total_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "measurements": {
          "type": "array",
          "minItems": 5,
          "items": {
            "$ref": "#/$defs/domainFootprint"
          }
        },
        "recommendations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/recommendation"
          }
        },
        "summary": {
          "$ref": "#/$defs/summary"
        }
      }
    },
    "domainFootprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "bytes",
        "reclaimable_bytes",
        "fragmentation_per_mille",
        "source"
      ],
      "properties": {
        "domain": {
          "$ref": "#/$defs/domain"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "reclaimable_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "fragmentation_per_mille": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "action",
        "reason_code",
        "risk",
        "measured_bytes",
        "projected_savings_bytes",
        "replay_command",
        "operator_command",
        "rationale"
      ],
      "properties": {
        "domain": {
          "$ref": "#/$defs/domain"
        },
        "action": {
          "$ref": "#/$defs/action"
        },
        "reason_code": {
          "$ref": "#/$defs/reasonCode"
        },
        "risk": {
          "$ref": "#/$defs/risk"
        },
        "measured_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "projected_savings_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "replay_command": {
          "$ref": "#/$defs/replayCommand"
        },
        "operator_command": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommendation_count",
        "projected_savings_bytes",
        "highest_risk"
      ],
      "properties": {
        "recommendation_count": {
          "type": "integer",
          "minimum": 1
        },
        "projected_savings_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "highest_risk": {
          "$ref": "#/$defs/risk"
        }
      }
    }
  }
}
