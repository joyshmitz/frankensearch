    {
      "id": "query-range-inclusive-created-at",
      "query_class": "range",
      "parser": "cass",
      "input": "cache",
      "filters": { "created_from": 1700000000000, "created_to": 1700000000999 },
      "expected_ast": {
        "type": "Boolean",
        "children": [
          { "occur": "Must", "query": { "type": "Term", "text": "cache", "fields": [{ "name": "title", "boost": 1.0 }, { "name": "content", "boost": 1.0 }, { "name": "title_prefix", "boost": 1.0 }, { "name": "content_prefix", "boost": 1.0 }] } },
          { "occur": "Must", "query": { "type": "RangeI64", "field": "created_at", "lower": { "value": 1700000000000, "bound": "Included" }, "upper": { "value": 1700000000999, "bound": "Included" }, "matched_score": 1.0 } }
        ]
      }
    },
    {
      "id": "query-cjk-all-bigrams",
      "query_class": "short_keyword",
      "parser": "cass",
      "input": "搜索引擎",
      "expected_ast": {
        "type": "Boolean",
        "operator": "AND",
        "children": [
          { "occur": "Must", "query": { "type": "Term", "text": "搜索", "fields": [{ "name": "title", "boost": 1.0 }, { "name": "content", "boost": 1.0 }, { "name": "title_prefix", "boost": 1.0 }, { "name": "content_prefix", "boost": 1.0 }] } },
          { "occur": "Must", "query": { "type": "Term", "text": "索引", "fields": [{ "name": "title", "boost": 1.0 }, { "name": "content", "boost": 1.0 }, { "name": "title_prefix", "boost": 1.0 }, { "name": "content_prefix", "boost": 1.0 }] } },
          { "occur": "Must", "query": { "type": "Term", "text": "引擎", "fields": [{ "name": "title", "boost": 1.0 }, { "name": "content", "boost": 1.0 }, { "name": "title_prefix", "boost": 1.0 }, { "name": "content_prefix", "boost": 1.0 }] } }
        ]
      }
    },
    {
      "id": "query-cjk-mixed-script-keeps-cjk-only",
      "query_class": "short_keyword",
      "parser": "cass",
      "input": "abc搜索def",
      "expected_ast": {
        "type": "Term",
        "text": "搜索",
        "fields": [{ "name": "title", "boost": 1.0 }, { "name": "content", "boost": 1.0 }, { "name": "title_prefix", "boost": 1.0 }, { "name": "content_prefix", "boost": 1.0 }]
      },
      "discarded_query_characters": "abcdef"
    },
    {
      "id": "query-cjk-single-character-unigram",
      "query_class": "short_keyword",
      "parser": "cass",
      "input": "搜",
      "expected_ast": {
