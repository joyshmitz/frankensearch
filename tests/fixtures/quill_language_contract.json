{
  "schema_version": 1,
  "contract_version": "1.0.0",
  "oracle": {
    "engine": "tantivy",
    "version": "0.26.1",
    "lockfile": "Cargo.lock",
    "default_conformance": "RankExact",
    "score_epsilon": 0.0001
  },
  "fixture_execution": {
    "lexical_loader_executes": ["schema", "analyzers", "helpers", "bm25_operation_order"],
    "quill_differential_executes": ["canonical_query_trees", "ranking", "statistics_transitions", "writer_reader_lifecycle", "snippets", "durability", "errors", "concurrency"]
  },
  "source_corpora": [
    {
      "id": "source-corpus-120",
      "path": "tests/fixtures/corpus.json",
      "expected_document_count": 120,
      "purpose": "120 documents spanning the shared five-cluster relevance corpus"
    },
    {
      "id": "source-queries-25",
      "path": "tests/fixtures/queries.json",
      "purpose": "harvested identifier, short-keyword, and natural-language relevance slices"
    },
    {
      "id": "source-quality-harness",
      "path": "crates/frankensearch-fsfs/tests/search_quality_harness.rs",
      "purpose": "load and differential quality harness for the shared corpus and query slices"
    }
  ],
  "analyzer_cases": [
    {
      "id": "analyzer-default-ascii-split-lower",
      "analyzer": "frankensearch_default",
      "input": "Rust POL-358",
      "expected_tokens": [
        { "text": "rust", "position": 0, "offset_from": 0, "offset_to": 4, "position_length": 1 },
        { "text": "pol", "position": 1, "offset_from": 5, "offset_to": 8, "position_length": 1 },
        { "text": "358", "position": 2, "offset_from": 9, "offset_to": 12, "position_length": 1 }
      ]
    },
    {
      "id": "analyzer-default-unicode-lower-offsets",
      "analyzer": "frankensearch_default",
      "input": "ÉCLAIR 東京",
      "expected_tokens": [
        { "text": "éclair", "position": 0, "offset_from": 0, "offset_to": 7, "position_length": 1 },
        { "text": "東京", "position": 1, "offset_from": 8, "offset_to": 14, "position_length": 1 }
      ]
    },
    {
      "id": "analyzer-default-unicode-lower-expansion",
      "analyzer": "frankensearch_default",
      "input": "İ",
      "expected_tokens": [
        { "text": "i̇", "position": 0, "offset_from": 0, "offset_to": 2, "position_length": 1 }
      ]
    },
    {
      "id": "analyzer-hyphen-compound-and-parts",
      "analyzer": "hyphen_normalize",
      "input": "BD-Q3FY search",
      "expected_tokens": [
        { "text": "bd-q3fy", "position": 0, "offset_from": 0, "offset_to": 7, "position_length": 1 },
        { "text": "bd", "position": 0, "offset_from": 0, "offset_to": 7, "position_length": 1 },
        { "text": "q3fy", "position": 0, "offset_from": 0, "offset_to": 7, "position_length": 1 },
        { "text": "search", "position": 1, "offset_from": 8, "offset_to": 14, "position_length": 1 }
      ]
    },
    {
      "id": "analyzer-hyphen-cjk-bigrams",
      "analyzer": "hyphen_normalize",
      "input": "搜索引擎",
      "expected_tokens": [
        { "text": "搜索", "position": 0, "offset_from": 0, "offset_to": 12, "position_length": 1 },
        { "text": "索引", "position": 0, "offset_from": 0, "offset_to": 12, "position_length": 1 },
        { "text": "引擎", "position": 0, "offset_from": 0, "offset_to": 12, "position_length": 1 }
      ]
    },
    {
      "id": "analyzer-prefix-no-hyphen-decompose",
      "analyzer": "prefix_normalize",
      "input": "bd-q3fy",
      "expected_tokens": [
        { "text": "bd-q3fy", "position": 0, "offset_from": 0, "offset_to": 7, "position_length": 1 }
      ]
    },
    {
      "id": "analyzer-cass-limit-256-kept",
      "analyzer": "hyphen_normalize",
      "generated_input": { "repeat": "A", "count": 256 },
      "expected_token_count": 1,
      "expected_token_bytes": 256,
      "expected_token_repeat": "a"
    },
    {
      "id": "analyzer-cass-limit-257-dropped",
      "analyzer": "hyphen_normalize",
      "generated_input": { "repeat": "A", "count": 257 },
      "expected_tokens": []
    },
    {
      "id": "analyzer-tantivy-index-limit-65530-kept",
      "analyzer": "frankensearch_default",
      "generated_input": { "repeat": "x", "count_bytes": 65530 },
      "token_admission": "kept",
      "applies_to": ["document_indexing"]
    },
    {
      "id": "analyzer-tantivy-index-limit-65531-dropped",
      "analyzer": "frankensearch_default",
      "generated_input": { "repeat": "x", "count_bytes": 65531 },
      "token_admission": "dropped",
      "diagnostic": "warning",
      "applies_to": ["document_indexing"]
    },
    {
      "id": "analyzer-quill-query-limit-65531-dropped",
      "analyzer": "frankensearch_default",
      "generated_input": { "repeat": "x", "count_bytes": 65531 },
      "token_admission": "dropped",
      "applies_to": ["quill_query_analysis"],
      "classification": "explicit Quill hardening amendment; Tantivy QueryParser does not enforce MAX_TOKEN_LEN",
      "ordinary_string_query_reachable": false
    }
  ],
  "helper_cases": [
    {
      "id": "helper-edge-prefix-ascii",
      "helper": "cass_generate_edge_ngrams",
      "input": "hello world",
      "expected": "he hel hell hello wo wor worl world"
    },
    {
      "id": "helper-edge-prefix-unicode",
      "helper": "cass_generate_edge_ngrams",
      "input": "éclair",
      "expected": "éc écl écla éclai éclair"
    },
    {
      "id": "helper-edge-prefix-cap-20",
      "helper": "cass_generate_edge_ngrams",
      "input": "abcdefghijklmnopqrstuvwxy",
      "last_expected_prefix": "abcdefghijklmnopqrst",
      "expected_prefix_count": 19
    },
    {
      "id": "helper-preview-unicode",
      "helper": "cass_build_preview",
      "input": "éclair",
      "max_chars": 3,
      "expected": "écl…"
    },
    {
      "id": "helper-preview-zero",
      "helper": "cass_build_preview",
      "input": "hello",
      "max_chars": 0,
      "expected": "…"
    },
    {
      "id": "helper-query-truncate-ascii",
      "helper": "truncate_query",
      "generated_input": { "repeat": "a", "count_chars": 10001 },
      "expected_chars": 10000,
      "backends": ["tantivy", "fts5"]
    },
    {
      "id": "helper-query-truncate-unicode",
      "helper": "truncate_query",
      "generated_input": { "repeat": "é", "count_chars": 10001 },
      "expected_chars": 10000,
      "expected_bytes": 20000,
      "backends": ["tantivy", "fts5"]
    }
  ],
  "parse_tree_cases": [
    {
      "id": "query-identifier-path-phrase",
      "query_class": "identifier",
      "parser": "default_lenient",
      "input": "src/main.rs",
      "source": "contract extension for the path-shaped identifier class",
      "expected_ast": {
        "type": "Phrase",
        "terms": ["src", "main", "rs"],
        "slop": 0,
        "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }]
      }
    },
    {
      "id": "query-identifier-raw-colon-dropped",
      "query_class": "identifier",
      "parser": "default_lenient",
      "input": "SearchIndex::new",
      "source": "tests/fixtures/queries.json",
      "expected_ast": { "type": "Empty" },
      "expected_diagnostic": "unknown field SearchIndex"
    },
    {
      "id": "query-short-keyword-default-or",
      "query_class": "short_keyword",
      "parser": "default_lenient",
      "input": "rust ownership borrowing",
      "expected_ast": {
        "type": "Boolean",
        "children": [
          { "occur": "Should", "query": { "type": "Term", "text": "rust", "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }] } },
          { "occur": "Should", "query": { "type": "Term", "text": "ownership", "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }] } },
          { "occur": "Should", "query": { "type": "Term", "text": "borrowing", "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }] } }
        ]
      }
    },
    {
      "id": "query-natural-language-default-or",
      "query_class": "natural_language",
      "parser": "default_lenient",
      "input": "how do transformers work for text embeddings",
      "expected_ast": {
        "type": "Boolean",
        "children": [
          { "occur": "Should", "query": { "type": "Term", "text": "how", "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }] } },
          { "occur": "Should", "query": { "type": "Term", "text": "do", "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }] } },
          { "occur": "Should", "query": { "type": "Term", "text": "transformers", "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }] } },
          { "occur": "Should", "query": { "type": "Term", "text": "work", "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }] } },
          { "occur": "Should", "query": { "type": "Term", "text": "for", "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }] } },
          { "occur": "Should", "query": { "type": "Term", "text": "text", "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }] } },
          { "occur": "Should", "query": { "type": "Term", "text": "embeddings", "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }] } }
        ]
      }
    },
    {
      "id": "query-phrase-both-fields",
      "query_class": "phrase",
      "parser": "default_lenient",
      "input": "\"error handling\"",
      "expected_ast": {
        "type": "Phrase",
        "terms": ["error", "handling"],
        "slop": 0,
        "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }]
      }
    },
    {
      "id": "query-quoted-single-token-is-term",
      "query_class": "phrase",
      "parser": "default_lenient",
      "input": "\"rust\"",
      "expected_ast": {
        "type": "Term",
        "text": "rust",
        "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }]
      }
    },
    {
      "id": "query-default-and-precedes-or",
      "query_class": "boolean",
      "parser": "default_lenient",
      "input": "rust OR ownership AND borrowing",
      "expected_ast": {
        "type": "Boolean",
        "operator": "OR",
        "children": [
          { "occur": "Should", "query": { "type": "Term", "text": "rust", "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }] } },
          { "occur": "Should", "query": { "type": "Boolean", "operator": "AND", "children": [
            { "occur": "Must", "query": { "type": "Term", "text": "ownership", "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }] } },
            { "occur": "Must", "query": { "type": "Term", "text": "borrowing", "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }] } }
          ] } }
        ]
      }
    },
    {
      "id": "query-default-field-and-boost",
      "query_class": "short_keyword",
      "parser": "default_lenient",
      "input": "title:rust^3",
      "expected_ast": {
        "type": "Boost",
        "factor": 3.0,
        "query": {
          "type": "Term",
          "text": "rust",
          "fields": [{ "name": "title", "boost": 2.0 }]
        }
      }
    },
    {
      "id": "query-default-all-negative-complement",
      "query_class": "boolean",
      "parser": "default_lenient",
      "input": "-deprecated",
      "expected_ast": {
        "type": "Boolean",
        "children": [
          { "occur": "MustNot", "query": { "type": "Term", "text": "deprecated", "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }], "score": 0.0 } },
          { "occur": "Should", "query": { "type": "All" } }
        ]
      },
      "expected_diagnostic": "all-negative query repaired with All"
    },
    {
      "id": "query-default-recursive-dedup",
      "query_class": "short_keyword",
      "parser": "default_lenient",
      "input": "rust rust",
      "expected_ast": {
        "type": "Term",
        "text": "rust",
        "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }]
      }
    },
    {
      "id": "query-lenient-unterminated-quote-recovers",
      "query_class": "short_keyword",
      "parser": "default_lenient",
      "input": "\"rust",
      "expected_ast": {
        "type": "Term",
        "text": "rust",
        "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }]
      },
      "expected_diagnostic": "syntax recovery"
    },
    {
      "id": "query-lenient-diagnostic-keeps-valid-sibling",
      "query_class": "short_keyword",
      "parser": "default_lenient",
      "input": "unknown_field:value rust",
      "expected_ast": {
        "type": "Boolean",
        "children": [
          { "occur": "Should", "query": { "type": "Term", "text": "rust", "fields": [{ "name": "content", "boost": 1.0 }, { "name": "title", "boost": 2.0 }] } }
        ]
      },
      "expected_diagnostic": "unsupported field fragment dropped"
    },
    {
      "id": "query-boolean-or-tighter-than-and",
      "query_class": "boolean",
      "parser": "cass",
      "input": "auth OR token AND cache",
      "expected_ast": {
        "type": "Boolean",
        "operator": "AND",
        "children": [
          { "occur": "Must", "query": { "type": "Boolean", "operator": "OR", "children": [
            { "occur": "Should", "query": { "type": "Term", "text": "auth", "fields": [{ "name": "title", "boost": 1.0 }, { "name": "content", "boost": 1.0 }, { "name": "title_prefix", "boost": 1.0 }, { "name": "content_prefix", "boost": 1.0 }] } },
            { "occur": "Should", "query": { "type": "Term", "text": "token", "fields": [{ "name": "title", "boost": 1.0 }, { "name": "content", "boost": 1.0 }, { "name": "title_prefix", "boost": 1.0 }, { "name": "content_prefix", "boost": 1.0 }] } }
          ] } },
          { "occur": "Must", "query": { "type": "Term", "text": "cache", "fields": [{ "name": "title", "boost": 1.0 }, { "name": "content", "boost": 1.0 }, { "name": "title_prefix", "boost": 1.0 }, { "name": "content_prefix", "boost": 1.0 }] } }
        ]
      }
    },
    {
      "id": "query-boolean-negative-standalone-universe",
      "query_class": "boolean",
      "parser": "cass",
      "input": "-deprecated",
      "expected_ast": {
        "type": "Boolean",
        "children": [
          { "occur": "Must", "query": { "type": "All" } },
          { "occur": "MustNot", "query": { "type": "Term", "text": "deprecated", "fields": [{ "name": "title", "boost": 1.0 }, { "name": "content", "boost": 1.0 }, { "name": "title_prefix", "boost": 1.0 }, { "name": "content_prefix", "boost": 1.0 }], "score": 0.0 } }
        ]
      },
      "known_shipping_gap": "cass_compat currently emits a negative-only BooleanQuery for this shape"
    },
    {
      "id": "query-boolean-negative-or-operand-universe",
      "query_class": "boolean",
      "parser": "cass",
      "input": "auth OR NOT deprecated",
      "expected_ast": {
        "type": "Boolean",
        "operator": "OR",
        "children": [
          { "occur": "Should", "query": { "type": "Term", "text": "auth", "fields": [{ "name": "title", "boost": 1.0 }, { "name": "content", "boost": 1.0 }, { "name": "title_prefix", "boost": 1.0 }, { "name": "content_prefix", "boost": 1.0 }] } },
          {
            "occur": "Should",
            "query": {
              "type": "Boolean",
              "children": [
                { "occur": "Must", "query": { "type": "All" } },
                { "occur": "MustNot", "query": { "type": "Term", "text": "deprecated", "fields": [{ "name": "title", "boost": 1.0 }, { "name": "content", "boost": 1.0 }, { "name": "title_prefix", "boost": 1.0 }, { "name": "content_prefix", "boost": 1.0 }], "score": 0.0 } }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "query-boolean-and-not-no-all-score",
      "query_class": "boolean",
      "parser": "cass",
      "input": "auth AND NOT deprecated",
      "expected_ast": {
        "type": "Boolean",
        "operator": "AND",
        "children": [
          { "occur": "Must", "query": { "type": "Term", "text": "auth", "fields": [{ "name": "title", "boost": 1.0 }, { "name": "content", "boost": 1.0 }, { "name": "title_prefix", "boost": 1.0 }, { "name": "content_prefix", "boost": 1.0 }] } },
          { "occur": "MustNot", "query": { "type": "Term", "text": "deprecated", "fields": [{ "name": "title", "boost": 1.0 }, { "name": "content", "boost": 1.0 }, { "name": "title_prefix", "boost": 1.0 }, { "name": "content_prefix", "boost": 1.0 }], "score": 0.0 } }
        ]
      }
    },
    {
      "id": "query-boolean-repeated-not-is-idempotent",
      "query_class": "boolean",
      "parser": "cass",
      "input": "auth AND NOT NOT deprecated",
      "expected_ast": {
        "type": "Boolean",
        "operator": "AND",
        "children": [
          { "occur": "Must", "query": { "type": "Term", "text": "auth", "fields": [{ "name": "title", "boost": 1.0 }, { "name": "content", "boost": 1.0 }, { "name": "title_prefix", "boost": 1.0 }, { "name": "content_prefix", "boost": 1.0 }] } },
          { "occur": "MustNot", "query": { "type": "Term", "text": "deprecated", "fields": [{ "name": "title", "boost": 1.0 }, { "name": "content", "boost": 1.0 }, { "name": "title_prefix", "boost": 1.0 }, { "name": "content_prefix", "boost": 1.0 }], "score": 0.0 } }
        ]
      },
      "double_negation": false
    },
    {
      "id": "query-glob-exact",
      "query_class": "glob",
      "parser": "cass",
      "input": "exact",
      "expected_ast": {
        "type": "Glob",
        "pattern": "exact",
        "class": "Exact",
        "strategy": "TermQuery",
        "fields": ["title", "content", "title_prefix", "content_prefix"]
      }
    },
    {
      "id": "query-glob-prefix",
      "query_class": "glob",
      "parser": "cass",
      "input": "prefix*",
      "expected_ast": {
        "type": "Glob",
        "pattern": "prefix*",
        "normalized_term": "prefix",
        "class": "Prefix",
        "strategy": "TermQuery",
        "fields": ["title", "content", "title_prefix", "content_prefix"]
      }
    },
    {
      "id": "query-glob-suffix",
      "query_class": "glob",
      "parser": "cass",
      "input": "*suffix",
      "expected_ast": {
        "type": "Glob",
        "pattern": "*suffix",
        "class": "Suffix",
        "strategy": "RegexQuery",
        "regex": ".*suffix$",
        "fields": ["content", "title"]
      }
    },
    {
      "id": "query-glob-substring",
      "query_class": "glob",
      "parser": "cass",
      "input": "*middle*",
      "expected_ast": {
        "type": "Glob",
        "pattern": "*middle*",
        "class": "Substring",
        "strategy": "RegexQuery",
        "regex": ".*middle.*",
        "fields": ["content", "title"]
      }
    },
    {
      "id": "query-glob-complex",
      "query_class": "glob",
      "parser": "cass",
      "input": "a*b*c",
      "expected_ast": {
        "type": "Glob",
        "pattern": "a*b*c",
        "class": "Complex",
        "strategy": "RegexQuery",
        "regex": "^a.*b.*c$",
        "fields": ["content", "title"],
